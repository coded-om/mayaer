# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real credentials

# ── Vercel Environment Variables (add these in your Vercel project settings) ──

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/budget-buddy?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# MongoDB Atlas App Services App ID (for Realm/client-side SDK, optional)
# Get it from: https://cloud.mongodb.com → App Services → your app
VITE_REALM_APP_ID=your-atlas-app-id-here
